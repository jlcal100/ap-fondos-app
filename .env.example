# ============================================================
#   AP Fondos — Variables de entorno
# ============================================================
# Copiar este archivo a .env para desarrollo local, o configurar
# cada variable en el proveedor de hosting (Railway, Heroku, etc.)
# ============================================================

# --- Base de datos (requerido) ---------------------------------
# Railway / Heroku suelen inyectar esta variable automáticamente.
# Formato: postgres://user:password@host:port/database
DATABASE_URL=postgres://postgres:password@localhost:5432/ap_fondos_dev

# --- Autenticación (requerido) ---------------------------------
# Secreto para firmar tokens JWT. Debe tener ≥32 caracteres aleatorios.
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_este_valor_por_48_bytes_aleatorios_en_hex

# --- CFDI / Facturama (requerido para Bloque B) ----------------
# Llave maestra AES-256-GCM para cifrar credenciales Facturama en BD.
# Debe ser exactamente 64 caracteres hex (32 bytes).
# Generar UNA SOLA VEZ con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️  Si se pierde esta llave, se pierden las credenciales cifradas.
FISCAL_ENCRYPTION_KEY=

# --- Servidor ---------------------------------------------------
PORT=3000
NODE_ENV=development

# --- Email SMTP (opcional, requerido para enviar CFDI por email) ---
# Gmail:    SMTP_HOST=smtp.gmail.com, SMTP_PORT=587  (usar app-password, no la password normal)
# Office365: SMTP_HOST=smtp.office365.com, SMTP_PORT=587
# SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey, SMTP_PASS=<api-key>
# Mailgun:  SMTP_HOST=smtp.mailgun.org,  SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AP Fondos <no-reply@mi-empresa.com>"
